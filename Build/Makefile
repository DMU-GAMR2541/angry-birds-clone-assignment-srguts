	$(MAKE) $(MAKESILENT) -f CMakeFiles/Annoyed_Flocks.dir/build.make CMakeFiles/Annoyed_Flocks.dir/src/main.cpp.o
.PHONY : src/main.cpp.o

src/main.i: src/main.cpp.i
.PHONY : src/main.i

# target to preprocess a source file
src/main.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Annoyed_Flocks.dir/build.make CMakeFiles/Annoyed_Flocks.dir/src/main.cpp.i
.PHONY : src/main.cpp.i

src/main.s: src/main.cpp.s
.PHONY : src/main.s

# target to generate assembly for a file
src/main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Annoyed_Flocks.dir/build.make CMakeFiles/Annoyed_Flocks.dir/src/main.cpp.s
.PHONY : src/main.cpp.s

